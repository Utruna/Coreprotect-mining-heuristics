# Config de l'API XRayGateway (api/). Copier en api/.env et remplir.
# api/.env est ignoré par git (voir .gitignore racine) : NE JAMAIS le committer.

# Token Bearer de la passerelle = gateway.token du plugin xray-gateway-plugin.
# OBLIGATOIRE : /sync et /report échouent sans lui. C'est le seul vrai secret.
GATEWAY_TOKEN=

# URL de la passerelle exposée par le plugin sur la MÊME machine.
# Déjà positionné dans docker-compose.yml (host.docker.internal:8787) ; ne
# décommenter ici que pour surcharger (port gateway.port différent, etc.).
#GATEWAY_URL=http://host.docker.internal:8787

# Chemin du miroir SQLite DANS le container (doit être sur le volume persistant
# monté par docker-compose). Déjà positionné dans docker-compose.yml.
#MIRROR_PATH=/data/mirror.db
